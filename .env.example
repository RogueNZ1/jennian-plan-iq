# Anthropic API — used by concept.functions.ts for plan reading (server-side only)
ANTHROPIC_API_KEY=

# Supabase — public keys safe to expose in the browser
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Supabase — server-side / edge function access
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# VITE_GEOMETRY_API_BASE — leave UNSET in prod (resolves to the same-origin /api/geometry proxy).
# A dev-only override (e.g. http://localhost:8000) goes in .env.development.local, NOT .env.local —
# Vite bakes .env.local into prod builds, which would ship localhost and break geometry on the live
# site. The cf-pages-postbuild guard fails the build if a non-proxy geometry base leaks into the bundle.
