<?xml version="1.0" encoding="UTF-16"?>
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Jennian 007 — twice-weekly market intelligence. Runs Sunday + Wednesday 10pm NZST (09:00 UTC).</Description>
  </RegistrationInfo>
  <Triggers>
    <!-- Wednesday 09:00 UTC -->
    <CalendarTrigger>
      <StartBoundary>2026-05-21T09:00:00</StartBoundary>
      <ScheduleByWeek>
        <WeeksInterval>1</WeeksInterval>
        <DaysOfWeek><Wednesday /></DaysOfWeek>
      </ScheduleByWeek>
    </CalendarTrigger>
    <!-- Sunday 09:00 UTC -->
    <CalendarTrigger>
      <StartBoundary>2026-05-24T09:00:00</StartBoundary>
      <ScheduleByWeek>
        <WeeksInterval>1</WeeksInterval>
        <DaysOfWeek><Sunday /></DaysOfWeek>
      </ScheduleByWeek>
    </CalendarTrigger>
  </Triggers>
  <Actions Context="Author">
    <Exec>
      <Command>REPLACE_WITH_FULL_PATH\jennian-007-scraper\.venv\Scripts\python.exe</Command>
      <Arguments>run_brief.py</Arguments>
      <WorkingDirectory>REPLACE_WITH_FULL_PATH\jennian-007-scraper</WorkingDirectory>
    </Exec>
  </Actions>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <ExecutionTimeLimit>PT2H</ExecutionTimeLimit>
    <Priority>7</Priority>
  </Settings>
</Task>
