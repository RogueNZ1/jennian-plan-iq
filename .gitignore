.nitro
*.local

# Wrangler / Cloudflare
.wrangler/
.dev.vars

# Supabase CLI cache
supabase/.temp/

# Claude Code local settings (machine-specific permissions)
**/.claude/settings.local.json

# Local env — secrets must never be committed
.env
.env.local
.env.*.local

# Playwright
/tests/e2e/fixtures/*.pdf
/test-results/
/playwright-report/

# Phase 1 harness — rendered plan image is derived from the (gitignored) plan PDF;
# the golden/replay JSON fixtures ARE committed so the offline replay test runs in CI.
/tests/phase1/__fixtures__/*.b64.txt

# Beddis baseline fixtures — client plan files are potentially sensitive client
# data + large binaries, and the rendered page images / extracted page text are
# derived from them. Commit ONLY the machine-readable answer key (ground-truth.json)
# and the harness; keep the source PDFs/workbook and all derived renders out of git.
/tests/fixtures/beddis/*.pdf
/tests/fixtures/beddis/*.xlsm
/tests/fixtures/beddis/_render/
/tests/fixtures/beddis/_pagetext/

# Harrison (Lot 9) baseline fixtures — second permanent validation set. Same rule
# as Beddis: commit ONLY ground-truth.json + README + the harness; keep the source
# PDFs/workbook and all derived renders/page-text out of git.
/tests/fixtures/harrison/*.pdf
/tests/fixtures/harrison/*.xlsm
/tests/fixtures/harrison/_render/
/tests/fixtures/harrison/_pagetext/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vercel
